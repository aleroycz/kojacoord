From 72bf21649475617311e6cc439b6f1468fdb1a0c9 Mon Sep 17 00:00:00 2001
From: Kubmichna <jmichna64@gmail.com>
Date: Fri, 5 Jun 2026 21:16:39 +0200
Subject: [PATCH] feat: proxy hardening (graceful shutdown, handshake/keepalive
 timeouts, health probes)

---
 crates/config/src/lib.rs                |  9 +++
 crates/proxy-core/src/net/connection.rs | 25 +++++--
 crates/proxy-core/src/net/relay.rs      | 18 +++++-
 crates/proxy-core/src/proxy.rs          | 86 ++++++++++++++++++++++++-
 src/main.rs                             |  8 ++-
 5 files changed, 138 insertions(+), 8 deletions(-)

diff --git a/crates/config/src/lib.rs b/crates/config/src/lib.rs
index c37fd2b..aa0c4b4 100644
--- a/crates/config/src/lib.rs
+++ b/crates/config/src/lib.rs
@@ -81,6 +81,11 @@ pub struct ProxySection {
 
     #[serde(default = "default_auth_url")]
     pub auth_url: String,
+
+    /// Maximum time (in ms) to wait for a client to send the initial handshake
+    /// packet after connecting. Protects against slow-loris attacks. Default: 5000.
+    #[serde(default = "default_handshake_timeout")]
+    pub handshake_timeout_ms: u64,
 }
 
 impl Default for ProxySection {
@@ -100,6 +105,7 @@ impl Default for ProxySection {
             server_id: generate_server_id(),
             eula_accepted: false,
             auth_url: default_auth_url(),
+            handshake_timeout_ms: default_handshake_timeout(),
         }
     }
 }
@@ -406,6 +412,9 @@ fn default_auth_url() -> String {
 fn default_metrics_bind() -> String {
     "127.0.0.1:9090".into()
 }
+fn default_handshake_timeout() -> u64 {
+    5000
+}
 
 fn generate_server_id() -> String {
     uuid::Uuid::new_v4().to_string()
diff --git a/crates/proxy-core/src/net/connection.rs b/crates/proxy-core/src/net/connection.rs
index 2b3e873..6686a29 100644
--- a/crates/proxy-core/src/net/connection.rs
+++ b/crates/proxy-core/src/net/connection.rs
@@ -287,12 +287,27 @@ impl ClientConnection {
 
         self.state.metrics.record_connection();
 
-        let handshake = self
-            .read_packet::<ServerboundHandshake>()
-            .await
-            .inspect_err(|_| {
+        let timeout_ms = self.state.config.proxy.handshake_timeout_ms;
+        let handshake = match tokio::time::timeout(
+            tokio::time::Duration::from_millis(timeout_ms),
+            self.read_packet::<ServerboundHandshake>(),
+        )
+        .await
+        {
+            Ok(Ok(hs)) => hs,
+            Ok(Err(e)) => {
                 self.state.metrics.record_failed_connection();
-            })?;
+                return Err(e);
+            },
+            Err(_elapsed) => {
+                self.state.metrics.record_failed_connection();
+                tracing::debug!(peer = %self.addr, timeout_ms, "handshake timed out");
+                return Err(ConnectionError::Io(std::io::Error::new(
+                    std::io::ErrorKind::TimedOut,
+                    "handshake timed out",
+                )));
+            },
+        };
 
         self.protocol_version = handshake.protocol_version.0 as u32;
 
diff --git a/crates/proxy-core/src/net/relay.rs b/crates/proxy-core/src/net/relay.rs
index 0673875..7625a83 100644
--- a/crates/proxy-core/src/net/relay.rs
+++ b/crates/proxy-core/src/net/relay.rs
@@ -168,10 +168,26 @@ impl PacketRelay {
                 if stopped_s2c_chk.load(Ordering::Acquire) {
                     return Ok(());
                 }
+                // Backend keepalive watchdog: if no S→C packet arrives within
+                // 30 seconds the backend is considered stalled (JVM GC pause,
+                // disk hang, etc.). Disconnect the player cleanly instead of
+                // leaving them in limbo with a leaked session slot.
                 let payload = tokio::select! {
                     biased;
                     _ = stop_s2c_wait.notified() => return Ok(()),
-                    r = read_packet(&mut *br_mut, backend_thresh) => r?,
+                    r = tokio::time::timeout(
+                        std::time::Duration::from_secs(30),
+                        read_packet(&mut *br_mut, backend_thresh),
+                    ) => match r {
+                        Ok(pkt) => pkt?,
+                        Err(_elapsed) => {
+                            tracing::warn!("relay: backend read timed out (30s) — disconnecting player");
+                            let msg = r#"{"text":"","extra":[{"text":"Connection Lost\n","bold":true,"color":"red"},{"text":"The backend server stopped responding.","color":"gray"}]}"#;
+                            let pkt = build_disconnect_packet(msg, proto);
+                            let _ = write_packet(&mut *cw_s2c.lock().await, &pkt, client_thresh).await;
+                            return Err(ConnectionError::Closed);
+                        }
+                    },
                 };
 
                 state_s2c.metrics.record_packet(payload.len());
diff --git a/crates/proxy-core/src/proxy.rs b/crates/proxy-core/src/proxy.rs
index cc44327..435b759 100644
--- a/crates/proxy-core/src/proxy.rs
+++ b/crates/proxy-core/src/proxy.rs
@@ -559,9 +559,69 @@ pub async fn accept_loop(state: Arc<ProxyState>) -> Result<(), anyhow::Error> {
         }
     });
 
+    // ── Backend Health Probing ──────────────────────────────────────────
+    // Periodically TCP-connect to every registered backend. On success set
+    // online=true; on failure set online=false. This lets the router skip
+    // downed servers immediately instead of making players wait for a
+    // connect timeout.
+    tokio::spawn({
+        let state = Arc::clone(&state);
+        async move {
+            let mut interval = tokio::time::interval(std::time::Duration::from_secs(10));
+            loop {
+                interval.tick().await;
+                let backends = state.server_registry.all();
+                for backend in &backends {
+                    let was_online = backend.is_online();
+                    let is_online = tokio::time::timeout(
+                        std::time::Duration::from_secs(3),
+                        tokio::net::TcpStream::connect(backend.address),
+                    )
+                    .await
+                    .map(|r| r.is_ok())
+                    .unwrap_or(false);
+
+                    backend
+                        .online
+                        .store(is_online, std::sync::atomic::Ordering::Relaxed);
+
+                    if was_online && !is_online {
+                        tracing::warn!(
+                            server = %backend.name,
+                            addr = %backend.address,
+                            "health probe: backend went OFFLINE"
+                        );
+                    } else if !was_online && is_online {
+                        tracing::info!(
+                            server = %backend.name,
+                            addr = %backend.address,
+                            "health probe: backend came ONLINE"
+                        );
+                    }
+                }
+            }
+        }
+    });
+
     tracing::info!("Accepting incoming connections...");
+
+    // ── Graceful Shutdown ──────────────────────────────────────────────
+    // Accept connections until we receive Ctrl-C (SIGINT). On signal:
+    //   1. Stop accepting new connections
+    //   2. Broadcast a warning to all online players
+    //   3. Wait up to 5 seconds for relays to finish
+    //   4. Kick remaining players with a clean disconnect message
     loop {
-        let (stream, peer_addr) = listener.accept().await?;
+        let accept_result = tokio::select! {
+            biased;
+            _ = tokio::signal::ctrl_c() => {
+                tracing::info!("Received shutdown signal — beginning graceful drain...");
+                break;
+            }
+            r = listener.accept() => r,
+        };
+
+        let (stream, peer_addr) = accept_result?;
         let peer = peer_addr.to_string();
 
         // Connection-flood protection: reject (and temp-ban) IPs opening
@@ -600,4 +660,28 @@ pub async fn accept_loop(state: Arc<ProxyState>) -> Result<(), anyhow::Error> {
             state.metrics.record_disconnection();
         });
     }
+
+    // ── Drain phase ────────────────────────────────────────────────────
+    let shutdown_msg = r#"{"text":"","extra":[{"text":"\n\n","color":"white"},{"text":"Kojacoord Network\n","bold":true,"color":"gold"},{"text":"─────────────────────\n","color":"gray"},{"text":"Server Shutting Down\n\n","bold":true,"color":"red"},{"text":"The proxy is restarting. Please reconnect in a moment.\n","color":"white"},{"text":"─────────────────────\n","color":"gray"},{"text":"discord.gg/yourserver","color":"aqua","underlined":true}]}"#;
+    state.broadcast_system_message(shutdown_msg).await;
+    tracing::info!("Shutdown warning broadcast — draining for 5 seconds...");
+
+    tokio::time::sleep(std::time::Duration::from_secs(5)).await;
+
+    // Kick any remaining players
+    let remaining: Vec<uuid::Uuid> = {
+        let sessions = state.sessions.read().await;
+        sessions.keys().copied().collect()
+    };
+    if !remaining.is_empty() {
+        tracing::info!(count = remaining.len(), "Kicking remaining players...");
+        for uuid in &remaining {
+            state.kick_player(uuid, shutdown_msg).await;
+        }
+        // Give kick packets a moment to flush
+        tokio::time::sleep(std::time::Duration::from_millis(500)).await;
+    }
+
+    tracing::info!("Graceful shutdown complete.");
+    Ok(())
 }
diff --git a/src/main.rs b/src/main.rs
index 55b2af1..c3f0d08 100644
--- a/src/main.rs
+++ b/src/main.rs
@@ -142,7 +142,13 @@ async fn main() -> anyhow::Result<()> {
         }
     });
 
-    kojacoord_proxy_core::proxy::accept_loop(state).await
+    if let Err(e) = kojacoord_proxy_core::proxy::accept_loop(state).await {
+        tracing::error!("Proxy loop ended with error: {:?}", e);
+        std::process::exit(1);
+    }
+
+    tracing::info!("Process exiting.");
+    std::process::exit(0);
 }
 
 fn save_config(config: &kojacoord_config::ProxyConfig, path: &str) -> anyhow::Result<()> {
